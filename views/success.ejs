<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>¡Formulario Enviado con Éxito!</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .success-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
        }
        .success-header {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            padding: 40px 20px;
            text-align: center;
        }
        .success-header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            font-weight: bold;
        }
        .success-header p {
            font-size: 1.2rem;
            opacity: 0.9;
            margin: 0;
        }
        .success-body {
            padding: 40px 30px;
            background: white;
        }
        .checkmark-circle {
            width: 120px;
            height: 120px;
            margin: 0 auto 30px;
            background: #28a745;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: scaleIn 0.5s ease-in-out;
        }
        .checkmark-circle svg {
            width: 60px;
            height: 60px;
            fill: white;
        }
        .info-list {
            list-style: none;
            padding: 0;
            margin: 30px 0;
        }
        .info-list li {
            padding: 15px 20px;
            margin-bottom: 10px;
            background: #f8f9fa;
            border-radius: 10px;
            border-left: 4px solid #28a745;
            animation: slideIn 0.5s ease-in-out;
            animation-fill-mode: both;
        }
        .info-list li:nth-child(1) { animation-delay: 0.1s; }
        .info-list li:nth-child(2) { animation-delay: 0.2s; }
        .info-list li:nth-child(3) { animation-delay: 0.3s; }
        .info-list li:nth-child(4) { animation-delay: 0.4s; }
        .info-list li:nth-child(5) { animation-delay: 0.5s; }
        .info-list li strong {
            color: #28a745;
            margin-right: 10px;
        }
        .btn-home {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            border: none;
            color: white;
            padding: 15px 40px;
            font-size: 1.2rem;
            border-radius: 50px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            margin-top: 20px;
            display: inline-block;
            text-decoration: none;
        }
        .btn-home:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(40, 167, 69, 0.4);
            color: white;
        }
        .btn-home i {
            margin-right: 10px;
        }
        @keyframes scaleIn {
            from {
                transform: scale(0);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 1;
            }
        }
        @keyframes slideIn {
            from {
                transform: translateX(-30px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        .whatsapp-float {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #25d366;
            color: white;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            text-align: center;
            font-size: 30px;
            line-height: 60px;
            box-shadow: 0 5px 20px rgba(37, 211, 102, 0.4);
            transition: all 0.3s ease;
            z-index: 100;
        }
        .whatsapp-float:hover {
            transform: scale(1.1);
            color: white;
        }
        @media (max-width: 768px) {
            .success-header h1 {
                font-size: 2rem;
            }
            .success-body {
                padding: 30px 20px;
            }
            .whatsapp-float {
                bottom: 20px;
                right: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card success-card">
                    <div class="success-header">
                        <div class="checkmark-circle">
                            <svg viewBox="0 0 24 24">
                                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                            </svg>
                        </div>
                        <h1>¡Formulario Enviado!</h1>
                        <p>Gracias por confiar en nosotros</p>
                    </div>
                    
                    <div class="success-body">
                        <h4 class="text-center mb-4" style="color: #333;">¿Qué sigue ahora?</h4>
                        
                        <ul class="info-list">
                            <li>
                                <strong>1.</strong> Hemos recibido toda la información de tu negocio correctamente
                            </li>
                            <li>
                                <strong>2.</strong> Nuestro equipo revisará los detalles en las próximas 24-48 horas
                            </li>
                            <li>
                                <strong>3.</strong> Te contactaremos por <span class="badge bg-success">WhatsApp</span> o <span class="badge bg-primary">Email</span> para confirmar los detalles
                            </li>
                            <li>
                                <strong>4.</strong> Comenzaremos con el diseño de tu página web profesional
                            </li>
                            <li>
                                <strong>5.</strong> Recibirás actualizaciones periódicas del progreso
                            </li>
                        </ul>

                        <div class="alert alert-info" role="alert">
                            <i class="fas fa-info-circle"></i>
                            <strong>Importante:</strong> Si no recibes noticias nuestras en 48 horas, por favor contáctanos directamente.
                        </div>

                        <div class="text-center">
                            <a href="/" class="btn-home">
                                <i class="fas fa-home"></i> Volver al Inicio
                            </a>
                        </div>

                        <hr class="my-4">

                        <div class="row text-center">
                            <div class="col-6">
                                <small class="text-muted">
                                    <i class="fas fa-clock"></i> Tiempo estimado<br>
                                    5-7 días hábiles
                                </small>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">
                                    <i class="fas fa-file-signature"></i> Folio: #<%= Date.now().toString().slice(-6) %>
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- WhatsApp Float Button -->
    <a href="https://wa.me/52<%= typeof telefono_contacto !== 'undefined' ? telefono_contacto : 'YOUR_WHATSAPP_NUMBER' %>" class="whatsapp-float" target="_blank">
        <i class="fab fa-whatsapp"></i>
    </a>

    <!-- Font Awesome -->
    <script src="https://kit.fontawesome.com/your-kit-id.js" crossorigin="anonymous"></script>
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Script opcional para confeti de celebración -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1"></script>
    <script>
        // Lanzar confeti cuando la página carga
        window.onload = function() {
            confetti({
                particleCount: 100,
                spread: 70,
                origin: { y: 0.6 },
                colors: ['#28a745', '#20c997', '#007bff', '#6610f2']
            });
            
            // Mostrar mensaje de éxito si viene de la URL
            const urlParams = new URLSearchParams(window.location.search);
            const status = urlParams.get('status');
            if (status === 'success') {
                console.log('Formulario enviado exitosamente');
            }
        };

        // Animación adicional al hacer scroll
        window.addEventListener('scroll', function() {
            const elements = document.querySelectorAll('.info-list li');
            elements.forEach(el => {
                const position = el.getBoundingClientRect();
                if (position.top < window.innerHeight && position.bottom > 0) {
                    el.style.opacity = '1';
                    el.style.transform = 'translateX(0)';
                }
            });
        });
    </script>
</body>
</html>
